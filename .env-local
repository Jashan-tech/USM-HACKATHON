# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (REQUIRED)
# Used for rate limiting and BullMQ job queue
# -----------------------------------------------------------------------------

# Redis connection URL (for Docker: redis://redis:6379, for local: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# DEEPSEEK CONFIGURATION (REQUIRED)
# Used for preventive follow-up messages and availability parsing
# -----------------------------------------------------------------------------

# DeepSeek API Key - get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-475fb4b11e384cce95870e4bd2b5382b


# DeepSeek Model to use (default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------

# Application URL (for callbacks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment mode (development, production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# -----------------------------------------------------------------------------

# Global rate limit per IP (requests per minute)
RATE_LIMIT_GLOBAL_PER_MINUTE=100

# Per-user rate limit (requests per minute)
RATE_LIMIT_USER_PER_MINUTE=60

# NPI API rate limit per user (requests per minute)
RATE_LIMIT_NPI_PER_MINUTE=10

# AI/LLM rate limit per user (requests per minute)
RATE_LIMIT_AI_PER_MINUTE=10

# -----------------------------------------------------------------------------
# OPTIONAL: EXTERNAL SERVICES (for future phases)
# -----------------------------------------------------------------------------

# NPI Registry API (free, no key required)
# NPI_REGISTRY_BASE_URL=https://npiregistry.cms.hhs.gov/api

# Twilio (for SMS/voice in Phase 4)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Availity/Change Healthcare (for Phase 2 real payer integration)
# AVAILITY_CLIENT_ID=your_availity_client_id
# AVAILITY_CLIENT_SECRET=your_availity_client_secret

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable development-only routes (email verification bypass)
# Set to 'true' only in local development
ENABLE_DEV_ROUTES=true
